\u8def\u200b\u3002\u200b\u800c\u200b  C/D\u200b\u8f6c\u6362\u200b\uff08\u200b\u8fde\u7eed\u200b\u5230\u200b\u79bb\u6563\u200b\uff09\u200b\u4e0e\u200b D/C\u200b\u8f6c\u6362\u200b\uff08\u200b\u79bb\u6563\u200b\u5230\u200b\u8fde\u7eed\u200b\uff09\u200b\u672c\u8d28\u200b\u4e0a\u200b\u662f\u200b\u6570\u5b66\u6a21\u578b\u200b\u6216\u200b\u7cfb\u7edf\u200b\u6846\u56fe\u200b\u4e2d\u200b\u7684\u200b\u4e00\u4e2a\u200b\u7406\u60f3\u5316\u200b\u6a21\u5757\u200b\u3002</p> <p>ADC\uff1a\u200b\u5c06\u200b\u8fde\u7eed\u200b\u53d8\u5316\u200b\u7684\u200b\u6a21\u62df\u4fe1\u53f7\u200b\uff08\u200b\u7535\u538b\u200b\u3001\u200b\u7535\u6d41\u200b\uff09\u200b\u8f6c\u6362\u200b\u4e3a\u200b\u79bb\u6563\u200b\u7684\u200b\u6570\u5b57\u4fe1\u53f7\u200b\uff08\u200b\u4e8c\u8fdb\u5236\u7801\u200b\uff09\u3002\u200b\u8fd9\u4e2a\u200b\u8fc7\u7a0b\u200b\u5fc5\u7136\u200b\u5305\u542b\u200b\u91c7\u6837\u200b\uff08\u200b\u65f6\u95f4\u200b\u79bb\u6563\u200b\u5316\u200b\uff09\u200b\u548c\u200b\u91cf\u5316\u200b\uff08\u200b\u5e45\u5ea6\u200b\u79bb\u6563\u200b\u5316\u200b\uff09\u3002</p> <p>DAC\uff1a\u200b\u5c06\u200b\u6570\u5b57\u4fe1\u53f7\u200b\u8f6c\u6362\u200b\u4e3a\u200b\u6a21\u62df\u4fe1\u53f7\u200b\u3002\u200b\u5b83\u200b\u901a\u5e38\u200b\u8f93\u51fa\u200b\u7684\u200b\u662f\u200b\u9636\u68af\u72b6\u200b\u7684\u200b\u6a21\u62df\u200b\u7535\u538b\u200b\uff0c\u200b\u9700\u8981\u200b\u540e\u7eed\u200b\u7684\u200b\u5e73\u6ed1\u200b\u6ee4\u6ce2\u5668\u200b\u624d\u80fd\u200b\u6062\u590d\u200b\u6210\u200b\u5e73\u6ed1\u200b\u7684\u200b\u6ce2\u5f62\u200b\u3002</p> <p>C/D\u200b\u8f6c\u6362\u200b\uff1a\u200b\u5728\u200b\u7406\u60f3\u200b\u6570\u5b66\u6a21\u578b\u200b\u4e2d\u5c06\u200b\u8fde\u7eed\u200b\u65f6\u95f4\u200b\u4fe1\u53f7\u200b \\(x_c(t)\\) \u200b\u8f6c\u6362\u200b\u4e3a\u200b\u79bb\u6563\u200b\u65f6\u95f4\u200b\u5e8f\u5217\u200b \\(x[n]\\) \u3002\u200b\u5728\u200b\u7406\u60f3\u200b\u60c5\u51b5\u200b\u4e0b\u200b\uff0c\u200b\u5b83\u200b\u53ea\u200b\u5173\u5fc3\u200b\u91c7\u6837\u200b\u5b9a\u7406\u200b\uff08\u200b\u65f6\u57df\u200b\u4e0a\u200b\u7684\u200b\u62bd\u53d6\u200b\uff09\uff0c\u200b\u901a\u5e38\u200b\u5ffd\u7565\u200b\u4e86\u200b\u786c\u4ef6\u200b\u5b9e\u73b0\u200b\u4e2d\u200b\u7684\u200b\u91cf\u5316\u200b\u8fc7\u7a0b\u200b\uff08\u200b\u8ba4\u4e3a\u200b\u5e45\u5ea6\u200b\u662f\u200b\u65e0\u9650\u200b\u7cbe\u5ea6\u200b\u7684\u200b\uff09\u3002</p> <p>D/C\u200b\u8f6c\u6362\u200b\uff1a\u200b\u5728\u200b\u7406\u60f3\u200b\u6570\u5b66\u6a21\u578b\u200b\u4e2d\u5c06\u200b\u79bb\u6563\u200b\u65f6\u95f4\u200b\u5e8f\u5217\u200b \\(y[n]\\text{ \u200b\u8f6c\u6362\u200b\u56de\u200b\u8fde\u7eed\u200b\u65f6\u95f4\u200b\u4fe1\u53f7\u200b }y_c(t)\\mathrm{\u3002}\\) \u3002\u200b\u5b83\u200b\u901a\u5e38\u200b\u88ab\u200b\u5efa\u6a21\u200b\u4e3a\u200b\u7406\u60f3\u200b\u5185\u200b\u63d2\u200b\uff08\u200b\u4f8b\u5982\u200b\u4f7f\u7528\u200b sinc \u200b\u51fd\u6570\u200b\uff09\uff0c\u200b\u65e8\u5728\u200b\u65e0\u200b\u5931\u771f\u200b\u5730\u200b\u91cd\u5efa\u200b\u5e26\u9650\u200b\u4fe1\u53f7\u200b\u3002</p>"},{"location":"NBU-NOTEBOOK/DSP/cp07/#dft_1","title":"\u7528\u200bDFT\u200b\u5904\u7406\u200b\u8fde\u7eed\u200b\u4fe1\u53f7","text":"<pre><code>\u200b\u4f7f\u7528\u200bDFT\u200b\u5904\u7406\u200b\u8fde\u7eed\u200b\u4fe1\u53f7\u200b\u7684\u200b\u6846\u56fe\u200b\u5982\u4e0b\u200b\uff1a\n</code></pre> <p>\u200b\u6297\u6df7\u53e0\u200b\u6ee4\u6ce2\u5668\u200b\uff1a\u200b\u672c\u8d28\u200b\u662f\u200b\u4f4e\u901a\u6ee4\u6ce2\u5668\u200b\uff0c\u200b\u7531\u4e8e\u200b\u4e0d\u200b\u5b58\u5728\u200b\u7406\u60f3\u200b\u6ee4\u6ce2\u5668\u200b\uff0c\u200b\u6240\u4ee5\u200b\u4f1a\u200b\u5b58\u5728\u200b\u5931\u771f\u200b\u3002</p> <p>\u200b\u6700\u5927\u200b\u533a\u522b\u200b\uff1a\u200b\u5c06\u200b\u8f6c\u6362\u200b\u540e\u200b\u7684\u200b\u79bb\u6563\u200b\u4fe1\u53f7\u200b\u7ecf\u8fc7\u200b\u4e00\u4e2a\u200b\u6709\u9650\u200b\u957f\u200b\u7684\u200b\u7a97\u200b\u51fd\u6570\u200b \\(\\mathit{w}[n]\\) \uff08\u200b\u5176\u200b\u9891\u57df\u200b\u4e3a\u200bSa\u200b\u51fd\u6570\u200b\uff09\u200b\u505a\u200b\u622a\u65ad\u200b\uff0c\u200b\u4f7f\u200b\u5176\u200b\u6210\u4e3a\u200b\u6709\u9650\u200b\u79bb\u6563\u200b\u4fe1\u53f7\u200b\uff0c\u200b\u7136\u540e\u200b\u8fdb\u884c\u200bDFT\u3002</p> <p>\u200b\u589e\u5927\u200b\u91c7\u6837\u200b\u9891\u7387\u200b\uff1a\u200b\u82e5\u200b\u60f3\u8981\u200b\u62bd\u6837\u200b\u95f4\u9694\u200b \\(\\frac{2\\pi}{N}\\) \u200b\u53d8\u5c0f\u200b\uff0c\u200b\u5219\u200b\u9700\u8981\u200bN\u200b\u589e\u5927\u200b\uff0c\u200b\u5373\u200b\u5728\u200b\u5b9e\u9645\u64cd\u4f5c\u200b\u4e2d\u5c06\u200b\u622a\u65ad\u200b\u540e\u200b\u7684\u200b\u79bb\u6563\u200b\u4fe1\u53f7\u200b\u6700\u540e\u200b\u5904\u8865\u200b0\u3002\u200b\u82e5\u200b\u7a97\u957f\u200b\u4e0d\u591f\u200b\uff0c\u200b\u5219\u200b\u6709\u200b\u53ef\u80fd\u200b\u5bfc\u81f4\u200b\u6ce2\u5cf0\u200b\u91cd\u5408\u200b\uff0c\u200b\u4ea7\u751f\u200b\u5931\u771f\u200b\u3002</p> <p>\u200b\u4e3b\u74e3\u200b\u5bbd\u5ea6\u200b\uff1a\u200b\u5176\u200b\u5927\u5c0f\u200b\u4e3a\u200b \\(\\frac{4\\pi}{N}\\) \uff0c\u200b\u4e0d\u4ec5\u200b\u4e0e\u200b\u7a97\u957f\u200b\u6709\u5173\u200b\uff0c\u200b\u8fd8\u200b\u4e0e\u200b\u622a\u65ad\u200b\u7a97\u200b\u7684\u200b\u5f62\u72b6\u200b\u6709\u5173\u200b\u3002</p>"},{"location":"NBU-NOTEBOOK/DSP/cp07/#_2","title":"\u79bb\u6563\u200b\u9891\u7387\u200b\u4e0e\u200b\u8fde\u7eed\u200b\u9891\u7387\u200b\u7684\u200b\u5173\u7cfb","text":"<p>DFT\u200b\u4e0e\u200bDTFT\uff1a\\(w_k=\\frac{2\\pi}{N}k\\)</p> <p>DTFT\u200b\u4e0e\u200bCTFT\uff1a\\(\u03a9_k=\\frac{2\\pi}{NT}k\\)</p> <p>\u200b\u7269\u7406\u200b\u9891\u7387\u200b:\\(f_k=\\frac{1}{NT}k\\)</p> <ul> <li>\u200b\u5176\u4e2d\u200b \\(\u03a9_k\\) \u200b\u662f\u200b\u8fde\u7eed\u200b\u9891\u7387\u200b\uff0c \\(f_k\\) \u200b\u662f\u200b\u7269\u7406\u200b\u9891\u7387\u200b</li> </ul>"},{"location":"NBU-NOTEBOOK/DSP/cp07/#_3","title":"\u9891\u7387\u200b\u5173\u7cfb\u200b\u7531\u200b\u5df2\u77e5\u200b\u70b9\u200b\u63a8\u200b\u4f4d\u7f6e\u200b\u70b9","text":"<ul> <li> \\[\\begin{aligned}&amp; \u200b\u82e5\u200bx_c(t)\u200b\u4e3a\u5b9e\u200b,\u200b\u5219\u200bx(n)\u200b\u4e3a\u5b9e\u200b,\u200b\u5219\u200b\u5f97\u200b V[k]=V^*[(-k)_N]\u3002\u200b\u5373\u82e5\u77e5\u200b\u4e00\u70b9\u200bV[a],\u200b\u5219\u200b\u53ef\u77e5\u200bV[N-a]\\end{aligned}\\] </li> <li>\u200b\u5373\u200b\uff1a\\({V}^*[a] = V[N - a]\\)</li> </ul>"},{"location":"NBU-NOTEBOOK/DSP/cp07/#dtftdft-dftctft","title":"DTFT\u200b\u63a8\u200bDFT\u200b\u9891\u7387\u200b DFT\u200b\u63a8\u200bCTFT","text":"<ul> <li> <p>\\(V[k]\\)\u200b\u63a8\u77e5\u200b\\(V[e^{jw}]\\)\uff08\u200b\u79bb\u6563\u200b\uff09\uff1a\\(V(e^{j(\\frac{2\\pi}{N})k})=V[k]\\)</p> </li> <li> <p>\\(V[k]\\)\u200b\u63a8\u77e5\u200b\\(V[j\u03a9]\\)\uff08\u200b\u8fde\u7eed\u200b\uff09\uff1a\\(V[j\u03a9]=T\u00b7V(e^{j(\\frac{2\\pi}{N})k})\\)</p> </li> </ul> <p>T\u200b\u7684\u200b\u6765\u6e90\u200b\uff1a\\(X(\\mathrm{e}^{\\mathrm{j}\\omega})=\\frac{1}{T}\\sum_{n=-\\infty}^{\\infty}X_{c}\\left(\\mathrm{j}\\frac{\\omega}{T}+\\mathrm{j}\\frac{2\\pi n}{T}\\right)\\)</p>"},{"location":"NBU-NOTEBOOK/DSP/cp07/#dft_2","title":"\u6b63\u5f26\u200b\u4fe1\u53f7\u200b\u7684\u200bDFT\u200b\u5206\u6790","text":"<ul> <li>\u200b\u6b63\u5f26\u200b\u4fe1\u53f7\u200b\u7684\u200bDFT\u200b\u5206\u6790\u200b\uff1a\u200b\u5c31\u662f\u200b\u5bf9\u7a97\u200b\u7684\u200b\u9891\u8c31\u200b\u4f4d\u79fb\u200b</li> </ul> \\[\\begin{equation}x[n]=A_{0}\\mathrm{cos}(\\omega_{0}n+\\theta_{0})+A_{1}\\mathrm{cos}(\\omega_{1}n+\\theta_{1}),\\quad-\\infty&lt;n&lt;\\infty\\end{equation}\\] \\[\\begin{equation}\\begin{aligned}V(\\mathrm{e}^{\\mathrm{j}\\omega})&amp;=\\frac{A_{0}}{2}\\mathrm{e}^{\\mathrm{j}\\theta_{0}}W(\\mathrm{e}^{\\mathrm{j}(\\omega-\\omega_{0})})+\\frac{A_{0}}{2}\\mathrm{e}^{-\\mathrm{j}\\theta_{0}}W(\\mathrm{e}^{\\mathrm{j}(\\omega+\\omega_{0})})\\\\&amp;+\\frac{A_{1}}{2}\\mathrm{e}^{\\mathrm{j}\\theta_{1}}W(\\mathrm{e}^{\\mathrm{j}(\\omega-\\omega_{1})})+\\frac{\\Lambda_{1}}{2}\\mathrm{e}^{-\\mathrm{j}\\theta_{1}}W(\\mathrm{e}^{\\mathrm{j}(\\omega+\\omega_{1})})\\end{aligned}\\end{equation}\\] <ul> <li> <p>\u200b\u4e0a\u200b\u56fe\u200b\u5206\u522b\u200b\u5c55\u793a\u200b\u4e86\u200b\u4e0d\u540c\u200b \\(w_0\\) \u200b\u4e0e\u200b \\(w_1\\) \u200b\u65f6\u200b\u7684\u200b\u573a\u666f\u200b\uff0c\u200b\u5f53\u200b \\(w_0-w_1\u2264\\frac{2\\pi}{N}+\\frac{2\\pi}{N}\\) \uff0c\u200b\u6ce2\u5cf0\u200b\u7684\u200b\u4e3b\u74e3\u200b\u5c31\u200b\u4f1a\u200b\u91cd\u53e0\u200b</p> </li> <li> <p>\u200b\u5bf9\u4e8e\u200b\u4e0d\u540c\u200b\u7684\u200b \\(w\\) \uff0c\u200b\u6ce2\u5cf0\u200b\u7684\u200b\u4e3b\u74e3\u200b\u662f\u200b\u76f8\u540c\u200b\u7684\u200b\uff0c\u200b\u90fd\u200b\u662f\u200b \\(\\frac{4\\pi}{N}\\)</p> </li> </ul> <p>\u200b\u4e3b\u74e3\u200b\u7684\u200b\u5f62\u72b6\u200b</p> <p>\u200b\u5bf9\u4e8e\u200b\u540c\u4e00\u4e2a\u200b30\u200b\u70b9\u200b\u7684\u200bDFT\uff0c\u200b\u82e5\u200b \\(x_1(n)\\) \u200b\u6709\u200b30\u200b\u4e2a\u200b\u6709\u6548\u200b\u70b9\u200b\uff0c\\(x_2(n)\\) \u200b\u6709\u200b20\u200b\u4e2a\u200b\u6709\u6548\u200b\u70b9\u200b\uff0c\u200b\u5219\u200b\u9700\u8981\u200b\u8865\u200b0\u200b\u81f3\u200b30\u200b\u4e2a\u70b9\u200b\uff0c\u200b\u4f46\u200b\u8865\u200b0\u200b\u5e76\u200b\u4e0d\u4f1a\u200b\u6539\u53d8\u200b\u6ce2\u200b\u7684\u200b\u5f62\u72b6\u200b</p>"},{"location":"NBU-NOTEBOOK/DSP/cp07/#_4","title":"\u9891\u7387\u200b\u5206\u8fa8\u7387","text":"<ul> <li>N\u200b\u4e3a\u200bDFT\u200b\u70b9\u6570\u200b\uff0cL\u200b\u4e3a\u200b\u7a97\u957f\u200b\uff08\u200b\u91c7\u6837\u200b\u70b9\u200b\u4e2a\u6570\u200b\uff09</li> </ul>"},{"location":"NBU-NOTEBOOK/DSP/cp07/#_5","title":"\u9891\u57df\u200b\u8fc7\u200b\u91c7\u6837","text":"<p>\u200b\u6982\u5ff5\u200b\uff1a\u200b\u53ea\u200b\u5bf9\u200b\u52a0\u7a97\u200b\u540e\u200b\u7684\u200b\u5e8f\u5217\u200b\u8865\u200b0\uff0c\u200b\u4e0d\u80fd\u200b\u63d0\u9ad8\u200b\u9891\u7387\u200b\u5206\u8fa8\u7387\u200b\uff08\u200b\u5e76\u200b\u4e0d\u200b\u589e\u52a0\u200b\u539f\u6709\u200b\u5e8f\u5217\u200b\u7684\u200b\u9891\u8c31\u200b\u4fe1\u606f\u200b\uff09\uff0c\u200b\u4f46\u200b\u53ef\u4ee5\u200b\u51cf\u5c0f\u200b\u8c31\u200b\u6837\u672c\u200b\u7684\u200b\u95f4\u8ddd\u200b</p> <p></p> <p>\u200b\u603b\u7ed3\u200b</p> <p>\u200b\u540c\u65f6\u200b\u589e\u52a0\u200b\u7a97\u957f\u200b(\u200b\u91c7\u6837\u200b\u70b9\u200b\u4e2a\u6570\u200b)\u200b\u4e0e\u200bDFT\u200b\u957f\u5ea6\u200b---\u200b\u8c31\u200b\u6837\u672c\u200b\u95f4\u8ddd\u200b\u51cf\u5c0f\u200b\uff0c\u200b\u5206\u522b\u200b\u7387\u200b\u63d0\u9ad8\u200b  </p> <p>\u200b\u589e\u52a0\u200bDFT\u200b\u957f\u5ea6\u200b\u4f46\u200b\u7a97\u957f\u200b\u4e0d\u53d8\u200b\uff08\u200b\u8865\u200b0\uff09---\u200b\u8c31\u200b\u6837\u672c\u200b\u95f4\u8ddd\u200b\u51cf\u5c0f\u200b\uff0c\u200b\u5206\u8fa8\u7387\u200b\u4e0d\u53d8\u200b</p>"},{"location":"NBU-NOTEBOOK/DSP/cp07/#dftfft","title":"DFT\uff08FFT\u200b\u7684\u200b\u8bef\u5dee\u200b\u6765\u6e90\u200b\uff09","text":"<ul> <li> <p>\u200b\u9891\u8c31\u200b\u6df7\u53e0\u200b\uff1a\u200b\u9891\u8c31\u200b\u6df7\u53e0\u200b\uff1a\u200b\u82e5\u200b\u91c7\u6837\u200b\u9891\u7387\u200b \\(F_s\\) \u200b\u4e0d\u200b\u6ee1\u8db3\u200b\u91c7\u6837\u200b\u5b9a\u7406\u200b\uff0c\u200b\u4f1a\u200b\u5728\u200b \\(0.5F_s\\) \u200b\u9644\u8fd1\u200b\u5f15\u8d77\u200b\u9891\u8c31\u200b\u6df7\u53e0\u200b\uff0c\u200b\u9020\u6210\u200b\u9891\u8c31\u200b\u5206\u6790\u200b\u8bef\u5dee\u200b\u3002\u200b\u89e3\u51b3\u200b\u65b9\u6cd5\u200b\u662f\u200b\u63d0\u9ad8\u200b\u91c7\u6837\u200b\u9891\u7387\u200b\u3002  </p> </li> <li> <p>\u200b\u622a\u65ad\u200b\u6548\u5e94\u200b\uff1a\u200b\u56e0\u4e3a\u200b DFT \u200b\u662f\u200b\u4e00\u79cd\u200b\u6709\u9650\u200b\u7684\u200b\u79bb\u6563\u200b\u5085\u7acb\u53f6\u200b\u53d8\u6362\u200b\uff0c\u200b\u56e0\u6b64\u200b\u8fdb\u884c\u200b\u8c31\u5206\u6790\u200b\u65f6\u200b\uff0c\u200b\u53ea\u80fd\u200b\u5bf9\u200b\u6a21\u62df\u4fe1\u53f7\u200b\u622a\u53d6\u200b\u4e00\u90e8\u5206\u200b\u8fdb\u884c\u200b\u5206\u6790\u200b\u3002\u200b\u6bd4\u8f83\u200b\u622a\u65ad\u200b\u524d\u540e\u200b\u7684\u200b\u5e45\u5ea6\u200b\u8c31\u200b\u4e3b\u8981\u200b\u6709\u200b\u6cc4\u9732\u200b\u548c\u200b\u8c31\u200b\u95f4\u200b\u5e72\u6270\u200b\u8fd9\u200b\u4e24\u79cd\u200b\u8bef\u5dee\u200b\u3002\u200b\u89e3\u51b3\u200b\u65b9\u6cd5\u200b\u662f\u200b\u589e\u52a0\u200b\u89c2\u6d4b\u200b\u65f6\u95f4\u200b\u548c\u200b\u9009\u62e9\u200b\u5408\u9002\u200b\u7684\u200b\u7a97\u200b\u51fd\u6570\u200b\u3002  </p> </li> <li> <p>\u200b\u6805\u680f\u200b\u6548\u5e94\u200b\uff1a\u200b\u4e00\u822c\u200b\u6a21\u62df\u4fe1\u53f7\u200b\u7684\u200b\u9891\u8c31\u200b\u662f\u200b\u8fde\u7eed\u51fd\u6570\u200b\uff0c\u200b\u4f46\u7528\u200b DFT \u200b\u8ba1\u7b97\u200b\u51fa\u200b\u7684\u200b\u9891\u8c31\u200b\u662f\u200b\u79bb\u6563\u8c31\u200b\uff0c\u200b\u6bcf\u200b\u4e24\u4e2a\u200b\u91c7\u6837\u200b\u70b9\u200b\u4e4b\u95f4\u200b\u7684\u200b\u9891\u8c31\u200b\u503c\u200b\u662f\u200b\u4e0d\u200b\u77e5\u9053\u200b\u7684\u200b\uff0c\u200b\u5c31\u200b\u50cf\u200b\u88ab\u200b\u6805\u680f\u200b\u906e\u4f4f\u200b\u4e00\u6837\u200b\uff0c\u200b\u8fd9\u79cd\u200b\u73b0\u8c61\u200b\u88ab\u200b\u79f0\u4e3a\u200b\u6805\u680f\u200b\u6548\u5e94\u200b\u3002\u200b\u89e3\u51b3\u200b\u65b9\u6cd5\u200b\u662f\u200b\u589e\u52a0\u200b DFT \u200b\u7684\u200b\u53d8\u6362\u200b\u70b9\u6570\u200b\u3002  </p> </li> </ul>"},{"location":"blog/","title":"Blog","text":""},{"location":"build_your_web/","title":"\u8bb0\u5f55\u200b\u4ece\u96f6\u5f00\u59cb\u200b\u7684\u200b\u7f51\u7ad9\u200b\u642d\u5efa\u200b[TODO]","text":""},{"location":"build_your_web/#todo","title":"\u8bb0\u5f55\u200b\u4ece\u96f6\u5f00\u59cb\u200b\u7684\u200b\u7f51\u7ad9\u200b\u642d\u5efa\u200b[TODO]","text":"<p>TAKE NOTE</p> <p>\u200b\u4f5c\u4e3a\u200b\u559c\u6b22\u200b\u6298\u817e\u200b\u7684\u200b\u4eba\u200b\uff0c\u200b\u6211\u200b\u8ba4\u4e3a\u200b\u642d\u5efa\u200b\u81ea\u5df1\u200b\u7684\u200b\u7f51\u7ad9\u200b\u53bb\u200b\u5206\u4eab\u200b\u8bb0\u5f55\u200b\u81ea\u5df1\u200b\u7684\u200b\u6210\u957f\u200b\u662f\u200b\u4e00\u4ef6\u200b\u5f88\u9177\u200b\u7684\u200b\u4e8b\u60c5\u200b~~    </p> <p>\u200b\u6301\u7eed\u200b\u66f4\u65b0\u200bing...</p> <p>TODO</p> <ul> <li> \u200b\u8bb0\u5f55\u200b\u4ece\u96f6\u5f00\u59cb\u200b\u7684\u200b\u7f51\u7ad9\u200b\u642d\u5efa\u200b\u6d41\u7a0b\u200b  <ul> <li> conda\u200b\u4e0b\u200b\u7684\u200b\u865a\u62df\u73af\u5883\u200b\u6784\u5efa\u200b</li> <li> \u200b\u7528\u200b mkdocs\u200b\u642d\u5efa\u200b\u5c5e\u4e8e\u200b\u4f60\u200b\u7684\u200b\u7f51\u7ad9\u200b</li> <li> \u200b\u7528\u200b github-page\u200b\u53d1\u5e03\u200b\u4f60\u200b\u7684\u200b\u7f51\u7ad9\u200b</li> <li> \u200b\u7528\u200b material\u200b\u4f18\u5316\u200b\u4f60\u200b\u7684\u200b\u7f51\u7ad9\u200b</li> </ul> </li> <li> \u200b\u5e38\u7528\u200b\u8bed\u6cd5\u200b\u901f\u67e5\u200b \u200b\u8001\u5e74\u75f4\u5446\u200b\u8868\u200b</li> </ul>"},{"location":"build_your_web/access%20your%20github.io/","title":"\u7f51\u7ad9\u200b\u642d\u5efa\u200b\u4e0e\u200b\u53d1\u5e03\u200b[TODO]","text":""},{"location":"build_your_web/access%20your%20github.io/#todo","title":"\u7f51\u7ad9\u200b\u642d\u5efa\u200b\u4e0e\u200b\u53d1\u5e03\u200b[TODO]","text":""},{"location":"build_your_web/markdown%20%E9%80%9F%E8%AE%B0/","title":"Markdown \u200b\u901f\u8bb0","text":""},{"location":"build_your_web/markdown%20%E9%80%9F%E8%AE%B0/#markdown","title":"Markdown \u200b\u901f\u8bb0","text":"<p>\u200b\u8fd9\u662f\u200b\u4e00\u4e2a\u200bMarkdown\u200b\u901f\u67e5\u8868\u200b</p>"},{"location":"build_your_web/markdown%20%E9%80%9F%E8%AE%B0/#\u57fa\u672c\u8bed\u6cd5","title":"markdown\u200b\u57fa\u672c\u200b\u8bed\u6cd5","text":"<p>\u200b\u4e0b\u9762\u200b\u662f\u200b\u4e00\u4e9b\u200b\u5e38\u7528\u200b\u7684\u200bmarkdown\u200b\u64cd\u4f5c\u200b\u8bb0\u5f55\u200b\u3002\u200b\u8be6\u7ec6\u200b\u5185\u5bb9\u200b\u8bf7\u200b\u70b9\u51fb\u200b \u200b\u8fd9\u91cc\u200b</p> \u200b\u6807\u9898\u200b\u5f3a\u8c03\u200b\u5f15\u7528\u200b\u5217\u8868\u200b\u4ee3\u7801\u200b\u94fe\u63a5\u200b\u56fe\u7247\u200b\u8868\u683c\u200b\u811a\u6ce8\u200b <pre><code># \u200b\u8fd9\u662f\u200b\u4e00\u7ea7\u200b\u6807\u9898\u200b\n## \u200b\u8fd9\u662f\u200b\u4e8c\u7ea7\u200b\u6807\u9898\u200b\n### \u200b\u8fd9\u662f\u200b\u4e09\u7ea7\u200b\u6807\u9898\u200b\n</code></pre> <pre><code>*\u200b\u659c\u4f53\u200b*  \n**\u200b\u7c97\u4f53\u200b**  \n***\u200b\u659c\u4f53\u200b\u52a0\u7c97\u200b***  \n--- \u200b\u5206\u9694\u7b26\u200b  \n~~\u200b\u5220\u9664\u200b\u7ebf\u200b~~  \n&lt;u&gt;\u200b\u4e0b\u5212\u7ebf\u200b&lt;/u&gt;     \n</code></pre> <p>\u200b\u5f15\u7528\u200b\u5185\u5bb9\u200b \u200b\u5f15\u7528\u200b\u5185\u5bb9\u200b\uff08\u200b\u8de8\u884c\u200b\u9700\u8981\u200b\u7a7a\u4e24\u683c\u200b\uff09</p> <pre><code>1. \u200b\u6709\u200b\u5e8f\u5217\u8868\u200b\n     - [x] \u200b\u65e0\u5e8f\u200b\u5217\u8868\u200b\n         - [ ] \u200b\u7f29\u8fdb\u200b\n2. \u200b\u6709\u200b\u5e8f\u5217\u8868\u200b\n</code></pre> <ol> <li>\u200b\u6709\u200b\u5e8f\u5217\u8868\u200b<ul> <li> \u200b\u65e0\u5e8f\u200b\u5217\u8868\u200b<ul> <li> \u200b\u7f29\u8fdb\u200b</li> </ul> </li> </ul> </li> <li>\u200b\u6709\u200b\u5e8f\u5217\u8868\u200b</li> </ol> <p><code>\u200b\u5355\u884c\u200b\u4ee3\u7801\u200b</code></p> \u200b\u4ee3\u7801\u200b\u5757\u200b\u6807\u9898\u200b<pre><code>    ```text title=\"\u200b\u4ee3\u7801\u200b\u5757\u200b\u6807\u9898\u200b\"  \n    \u200b\u591a\u884c\u200b\u4ee3\u7801\u200b\u5757\u200b  \n    ```\n</code></pre> <pre><code>print(\"hello world\")\n</code></pre> <p></p><pre><code>***[\u200b\u94fe\u63a5\u200b\u540d\u79f0\u200b](\u200b\u94fe\u63a5\u200b\u5730\u5740\u200b \"\u200b\u60ac\u505c\u200blabel\")***\n&lt;\u200b\u76f4\u94fe\u200b&gt;\n</code></pre> \u200b\u535a\u5ba2\u5730\u5740\u200b <p>https://dixilog.github.io</p> <pre><code>[![\u200b\u56fe\u7247\u200b\u540d\u79f0\u200b](\u200b\u56fe\u7247\u200b\u5730\u5740\u200b \"\u200b\u60ac\u505c\u200blabel\")](\u200b\u8d85\u94fe\u63a5\u200b\u5730\u5740\u200b)\n</code></pre> <p></p><pre><code>| \u200b\u8868\u5934\u200b1 | \u200b\u8868\u5934\u200b2 | \u200b\u8868\u5934\u200b3 |\n| :--- | :---: | -----:|\n| \u200b\u5355\u5143\u683c\u200b &lt;br&gt;  \u200b\u6362\u884c\u200b | \u200b\u5355\u5143\u683c\u200b2222222 | \u200b\u5355\u5143\u683c\u200b333333 |\n| `\u200b\u5de6\u200b\u5bf9\u9f50\u200b` | **\u200b\u5c45\u4e2d\u200b** | \u200b\u53f3\u200b\u5bf9\u9f50\u200b |\n</code></pre> \u200b\u8868\u5934\u200b1 \u200b\u8868\u5934\u200b2 \u200b\u8868\u5934\u200b3 \u200b\u5355\u5143\u683c\u200b   \u200b\u6362\u884c\u200b \u200b\u5355\u5143\u683c\u200b2222222 \u200b\u5355\u5143\u683c\u200b333333 <code>\u200b\u5de6\u200b\u5bf9\u9f50\u200b</code> \u200b\u5c45\u4e2d\u200b \u200b\u53f3\u200b\u5bf9\u9f50\u200b <pre><code>Here's a simple footnote.[^1]\n\n[^1]: \u200b\u8fd9\u200b\u662f\u200b\u4f60\u200b\u7684\u200b\u811a\u6ce8\u200b\u3002\n</code></pre> <p>Here's a simple footnote.<sup>1</sup></p>"},{"location":"build_your_web/markdown%20%E9%80%9F%E8%AE%B0/#pythonmarkdown","title":"python\u2014markdown","text":"<p>display basic usage of markdown in python details click here</p>"},{"location":"build_your_web/markdown%20%E9%80%9F%E8%AE%B0/#_1","title":"\u7f29\u5199","text":"\u7f29\u5199\u200b\u683c\u5f0f\u200b,\u200b\u4e5f\u200b\u53ef\u4f5c\u200b\u82f1\u6587\u200b\u6ce8\u91ca\u200b<pre><code>The HTML specification is maintained by the W3C.\n\n*[HTML]: Hyper Text Markup Language\n*[W3C]:  World Wide Web Consortium\n</code></pre> <p>Example\uff1aThe HTML specification is maintained by the W3C.</p>"},{"location":"build_your_web/markdown%20%E9%80%9F%E8%AE%B0/#tag","title":"\u6807\u9898\u200btag","text":"\u6807\u9898\u200btag\uff0c\u200b\u7528\u4e8e\u200b\u6587\u4ef6\u200b\u5185\u200b\u8df3\u8f6c\u200b<pre><code># \u200b\u6807\u9898\u200b1{: #title1 }\n\n[name_yourself](#title1)\n</code></pre> <p>Example:\u200b\u8df3\u8f6c\u200b\u5230\u200b\u57fa\u672c\u200b\u8bed\u6cd5\u200b\u90e8\u5206\u200b</p> <p>\u200b\u53ef\u80fd\u200b\u51fa\u73b0\u200b\u5355\u70b9\u200b\u65e0\u6548\u200b\u7684\u200b\u60c5\u51b5\u200b\uff0c\u200b\u9700\u8981\u200b\u518d\u6b21\u200b\u5