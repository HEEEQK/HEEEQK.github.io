00b\n     - [x] \u200b\u65e0\u5e8f\u200b\u5217\u8868\u200b\n         - [ ] \u200b\u7f29\u8fdb\u200b\n2. \u200b\u6709\u200b\u5e8f\u5217\u8868\u200b\n</code></pre> <ol> <li>\u200b\u6709\u200b\u5e8f\u5217\u8868\u200b<ul> <li> \u200b\u65e0\u5e8f\u200b\u5217\u8868\u200b<ul> <li> \u200b\u7f29\u8fdb\u200b</li> </ul> </li> </ul> </li> <li>\u200b\u6709\u200b\u5e8f\u5217\u8868\u200b</li> </ol> <p><code>\u200b\u5355\u884c\u200b\u4ee3\u7801\u200b</code></p> \u200b\u4ee3\u7801\u200b\u5757\u200b\u6807\u9898\u200b<pre><code>    ```text title=\"\u200b\u4ee3\u7801\u200b\u5757\u200b\u6807\u9898\u200b\"  \n    \u200b\u591a\u884c\u200b\u4ee3\u7801\u200b\u5757\u200b  \n    ```\n</code></pre> <pre><code>print(\"hello world\")\n</code></pre> <p></p><pre><code>***[\u200b\u94fe\u63a5\u200b\u540d\u79f0\u200b](\u200b\u94fe\u63a5\u200b\u5730\u5740\u200b \"\u200b\u60ac\u505c\u200blabel\")***\n&lt;\u200b\u76f4\u94fe\u200b&gt;\n</code></pre> \u200b\u535a\u5ba2\u5730\u5740\u200b <p>https://dixilog.github.io</p> <pre><code>[![\u200b\u56fe\u7247\u200b\u540d\u79f0\u200b](\u200b\u56fe\u7247\u200b\u5730\u5740\u200b \"\u200b\u60ac\u505c\u200blabel\")](\u200b\u8d85\u94fe\u63a5\u200b\u5730\u5740\u200b)\n</code></pre> <p></p><pre><code>| \u200b\u8868\u5934\u200b1 | \u200b\u8868\u5934\u200b2 | \u200b\u8868\u5934\u200b3 |\n| :--- | :---: | -----:|\n| \u200b\u5355\u5143\u683c\u200b &lt;br&gt;  \u200b\u6362\u884c\u200b | \u200b\u5355\u5143\u683c\u200b2222222 | \u200b\u5355\u5143\u683c\u200b333333 |\n| `\u200b\u5de6\u200b\u5bf9\u9f50\u200b` | **\u200b\u5c45\u4e2d\u200b** | \u200b\u53f3\u200b\u5bf9\u9f50\u200b |\n</code></pre> \u200b\u8868\u5934\u200b1 \u200b\u8868\u5934\u200b2 \u200b\u8868\u5934\u200b3 \u200b\u5355\u5143\u683c\u200b   \u200b\u6362\u884c\u200b \u200b\u5355\u5143\u683c\u200b2222222 \u200b\u5355\u5143\u683c\u200b333333 <code>\u200b\u5de6\u200b\u5bf9\u9f50\u200b</code> \u200b\u5c45\u4e2d\u200b \u200b\u53f3\u200b\u5bf9\u9f50\u200b <pre><code>Here's a simple footnote.[^1]\n\n[^1]: \u200b\u8fd9\u200b\u662f\u200b\u4f60\u200b\u7684\u200b\u811a\u6ce8\u200b\u3002\n</code></pre> <p>Here's a simple footnote.<sup>1</sup></p>"},{"location":"build_your_web/markdown%20%E9%80%9F%E8%AE%B0/#pythonmarkdown","title":"python\u2014markdown","text":"<p>display basic usage of markdown in python details click here</p>"},{"location":"build_your_web/markdown%20%E9%80%9F%E8%AE%B0/#_1","title":"\u7f29\u5199","text":"\u7f29\u5199\u200b\u683c\u5f0f\u200b,\u200b\u4e5f\u200b\u53ef\u4f5c\u200b\u82f1\u6587\u200b\u6ce8\u91ca\u200b<pre><code>The HTML specification is maintained by the W3C.\n\n*[HTML]: Hyper Text Markup Language\n*[W3C]:  World Wide Web Consortium\n</code></pre> <p>Example\uff1aThe HTML specification is maintained by the W3C.</p>"},{"location":"build_your_web/markdown%20%E9%80%9F%E8%AE%B0/#tag","title":"\u6807\u9898\u200btag","text":"\u6807\u9898\u200btag\uff0c\u200b\u7528\u4e8e\u200b\u6587\u4ef6\u200b\u5185\u200b\u8df3\u8f6c\u200b<pre><code># \u200b\u6807\u9898\u200b1{: #title1 }\n\n[name_yourself](#title1)\n</code></pre> <p>Example:\u200b\u8df3\u8f6c\u200b\u5230\u200b\u57fa\u672c\u200b\u8bed\u6cd5\u200b\u90e8\u5206\u200b</p> <p>\u200b\u53ef\u80fd\u200b\u51fa\u73b0\u200b\u5355\u70b9\u200b\u65e0\u6548\u200b\u7684\u200b\u60c5\u51b5\u200b\uff0c\u200b\u9700\u8981\u200b\u518d\u6b21\u200b\u5355\u51fb\u200b</p>"},{"location":"build_your_web/markdown%20%E9%80%9F%E8%AE%B0/#_2","title":"\u6bb5\u843d\u200b\u7f29\u8fdb","text":"\u5192\u53f7\u200b + tab<pre><code>dixi\n:   dixiLOG\n    a magic bolg  \n    :   what c i say?  \n        amazing!\n</code></pre> dixi dixiLOG a magic bolg what c i say? amazing!"},{"location":"build_your_web/markdown%20%E9%80%9F%E8%AE%B0/#_3","title":"\u9ad8\u4eae\u200b\u5757","text":"<p>\u200b\u53ef\u80fd\u200b\u662f\u200b\u4f7f\u7528\u200b\u6700\u591a\u200b\u7684\u200b\u90e8\u5206\u200b</p> \u200b\u683c\u5f0f\u200b<pre><code>!!! type \"name\"\n    content\n</code></pre> <p>info</p> <p>\u200b\u8fd9\u91cc\u200b\u662f\u200binfo\u200b\u5757\u200b</p> <p>success</p> <p>\u200b\u8fd9\u91cc\u200b\u662f\u200bsuccess\u200b\u5757\u200b</p> <p>tip</p> <p>\u200b\u8fd9\u91cc\u200b\u662f\u200btip\u200b\u5757\u200b</p> <p>quote</p> <p>\u200b\u8fd9\u91cc\u200b\u662f\u200bquote\u200b\u5757\u200b</p> <p>note</p> <p>\u200b\u8fd9\u91cc\u200b\u662f\u200bnote\u200b\u5757\u200b</p> <p>abstract</p> <p>\u200b\u8fd9\u91cc\u200b\u662f\u200babstract\u200b\u5757\u200b</p> <p>question</p> <p>\u200b\u8fd9\u91cc\u200b\u662f\u200bquestion\u200b\u5757\u200b</p> <p>example</p> <p>\u200b\u8fd9\u91cc\u200b\u662f\u200bexample\u200b\u5757\u200b</p> <p>warning</p> <p>\u200b\u8fd9\u91cc\u200b\u662f\u200bwarning\u200b\u5757\u200b</p> <p>failure</p> <p>\u200b\u8fd9\u91cc\u200b\u662f\u200bfailure\u200b\u5757\u200b</p> <p>bug</p> <p>\u200b\u8fd9\u91cc\u200b\u662f\u200bbug\u200b\u5757\u200b</p> <p>danger</p> <p>\u200b\u8fd9\u91cc\u200b\u662f\u200bdanger\u200b\u5757\u200b</p>"},{"location":"build_your_web/markdown%20%E9%80%9F%E8%AE%B0/#_4","title":"\u6298\u53e0\u200b\u4e0e\u200b\u5206\u680f","text":"\u6298\u53e0\u200b\u683c\u5f0f\u200b<pre><code>??? type \"name\"\n    content\n</code></pre> \u200b\u5206\u680f\u200b\u683c\u5f0f\u200b<pre><code>=== \"name1\"\n    content\n\n=== \"name2\"\n    content\n</code></pre> \u200b\u5206\u680f\u200b1\u200b\u5206\u680f\u200b2 danger <p>\u200b\u8fd9\u91cc\u200b\u662f\u200bdanger\u200b\u5757\u200b</p> <p>danger</p> <p>\u200b\u8fd9\u91cc\u200b\u662f\u200bdanger\u200b\u5757\u200b</p>"},{"location":"build_your_web/markdown%20%E9%80%9F%E8%AE%B0/#_5","title":"\u76ee\u5f55\u200b\u751f\u6210","text":"\u5c31\u200b\u4e00\u884c\u200b<pre><code>[TOC]\n</code></pre> <p>\u200b\u6e32\u67d3\u200b\u7ed3\u679c\u200b</p> Contents<ul> <li>Markdown \u200b\u901f\u8bb0\u200b<ul> <li>markdown\u200b\u57fa\u672c\u200b\u8bed\u6cd5\u200b</li> <li>python\u2014markdown<ul> <li>\u200b\u7f29\u5199\u200b</li> <li>\u200b\u6807\u9898\u200btag</li> <li>\u200b\u6bb5\u843d\u200b\u7f29\u8fdb\u200b</li> <li>\u200b\u9ad8\u4eae\u200b\u5757\u200b</li> <li>\u200b\u6298\u53e0\