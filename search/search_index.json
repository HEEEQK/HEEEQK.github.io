66f4\u200b\u4f4e\u200b      \uff084\uff09\u200b\u4e00\u822c\u200b\u60c5\u51b5\u200b\u4e0b\u200b\uff0c\u200b\u529f\u8017\u200b\u4e0e\u200b\u6210\u672c\u200b\u66f4\u9ad8\u200b  </li> </ul> \u200b\u7b80\u8ff0\u200b\u7528\u200b\u53cc\u200b\u7ebf\u6027\u53d8\u6362\u200b\u6cd5\u200b\u8bbe\u8ba1\u200b\u6570\u5b57\u200b\u4f4e\u901a\u6ee4\u6ce2\u5668\u200b\u7684\u200b\u6b65\u9aa4\u200b <ul> <li> <p>\uff081\uff09\u200b\u786e\u5b9a\u200b\u6570\u5b57\u200b\u4f4e\u901a\u6ee4\u6ce2\u5668\u200b\u7684\u200b\u6280\u672f\u6307\u6807\u200b\uff1a\\(\\omega_p\\)\u3001\\(\\omega_s\\)\u3001\\(\\alpha_p\\)\u3001\\(\\alpha_s\\) </p> </li> <li> <p>\uff082\uff09\u200b\u8fdb\u884c\u200b\u975e\u7ebf\u6027\u200b\u9884\u200b\u7578\u53d8\u200b\u77eb\u6b63\u200b\uff0c\u200b\u5c06\u200b\u6570\u5b57\u200b\u6ee4\u6ce2\u5668\u200b\u8f6c\u6362\u6210\u200b\u6a21\u62df\u200b\u6ee4\u6ce2\u5668\u200b\u6280\u672f\u6307\u6807\u200b\uff1a\\(\\Omega_{p}=\\frac{2}{T}\\tan\\frac{\\omega_{p}}{2},\\Omega_{s}=\\frac{2}{T}\\tan\\frac{\\omega_{s}}{2}\\) </p> </li> <li>\uff083\uff09\u200b\u8bbe\u8ba1\u200b\u6ee1\u8db3\u200b\u6307\u6807\u200b\u8981\u6c42\u200b\u7684\u200b\u8fc7\u5ea6\u200b\u6a21\u62df\u200b\u6ee4\u6ce2\u5668\u200b\u7684\u200b\u7cfb\u7edf\u200b\u51fd\u6570\u200b\\(H_a(s)\\) </li> <li>\uff084\uff09\u200b\u5c06\u200b\u6a21\u62df\u200b\u6ee4\u6ce2\u5668\u200b \\(H_a(s)\\) \u200b\u4ece\u200bs\u200b\u5e73\u9762\u200b\u8f6c\u6362\u200b\u5230\u200bz\u200b\u5e73\u9762\u200b\uff0c\u200b\u5f97\u5230\u200b\u6570\u5b57\u200b\u6ee4\u6ce2\u5668\u200b\u7684\u200b\u7cfb\u7edf\u200b\u51fd\u6570\u200b\\(H(z)\\) \uff0c\u200b\u5373\u200b\u5f97\u5230\u200b\\(H\\left(z\\right)=H_{a}\\left(s\\right)\\vert_{S=\\frac{2}{T}\\cdot\\frac{1-z^{-1}}{1+z^{-1}}}\\) \uff0c\u200b\u7531\u4e8e\u200b\u88c5\u200b\u7ebf\u6027\u53d8\u6362\u200b\u6cd5\u65e0\u200b\u9891\u8c31\u200b\u6df7\u53e0\u200b\u95ee\u9898\u200b\uff0c\u200b\u6240\u4ee5\u200bT\u200b\u53ef\u4ee5\u200b\u4efb\u610f\u200b\u53d6\u200b\uff0c\u200b\u4e00\u822c\u200b\u53d6\u200b2  </li> </ul> <p>\u200b\u4ece\u200b \\(X_M(k)\\) \u200b\u5bf9\u5e94\u200b\u7684\u200b\u65f6\u57df\u200b\u6709\u9650\u200b\u957f\u200b\u5e8f\u5217\u200b\\(x_M(n)\\) \u200b\u5c31\u662f\u200b\u539f\u200b\u5e8f\u5217\u200b\\(x(n)\\)\u200b\u4ee5\u200bM\u200b\u4e3a\u200b\u5468\u671f\u200b\u505a\u200b\u5ef6\u62d3\u200b\u7684\u200b\u4e3b\u503c\u200b\u5e8f\u5217\u200b</p> \u200b\u5229\u7528\u200b\u7a97\u200b\u51fd\u6570\u200b\u6cd5\u200b\u8bbe\u8ba1\u200bFIRDF\u200b\u7684\u200b\u6b65\u9aa4\u200b <ul> <li>\uff081\uff09    </li> <li>\uff082\uff09  </li> <li>\uff083\uff09  </li> <li>\uff084\uff09  </li> </ul> \u200b\u5229\u7528\u200b\u7a97\u200b\u51fd\u6570\u200b\u6cd5\u200b\u8bbe\u8ba1\u200bFIRDF\u200b\u7684\u200b\u6b65\u9aa4\u200b <ul> <li>\uff081\uff09    </li> <li>\uff082\uff09  </li> <li>\uff083\uff09  </li> <li>\uff084\uff09  </li> </ul> \u200b\u5df2\u77e5\u200b\u5e8f\u5217\u200b \\(x_n\\) \u200b\u7684\u200b\u957f\u5ea6\u200b\u4e3a\u200b M \uff0c\u200b\u5e76\u4e14\u200b\u7a33\u5b9a\u200b\uff0c\u200b\u5199\u51fa\u200b\u8be5\u200b\u5e8f\u5217\u200b\u7684\u200b\uff08\u200b\u79bb\u6563\u200b\u65f6\u95f4\u200b\uff09\u200b\u5085\u91cc\u53f6\u200b\u53d8\u6362\u200b\u3001N\u200b\u70b9\u200b\u79bb\u6563\u200b\u5085\u91cc\u53f6\u200b\u53d8\u6362\u200b\u3001Z\u200b\u53d8\u6362\u200b\u516c\u5f0f\u200b <ul> <li> <p>\uff081\uff09DFTF\uff1a \\(X(e^{j\\omega}) = \\text{FT}[x(n)] = \\sum_{n=0}^{M-1} x(n)e^{-j\\omega n}\\) </p> </li> <li> <p>\uff082\uff09DFT\uff1a\\(X(k) = \\text{DFT}[x(n)]_N = \\sum_{n=0}^{M-1} x(n)e^{-j\\frac{2\\pi}{N}kn}, \\quad k = 0,1,2,\\dots,N-1\\) </p> </li> <li> <p>\uff083\uff09ZT\uff1a\\(\\text{ZT}[x(n)] = \\sum_{n=0}^{M-1} x(n)z^{-n}\\) </p> </li> <li>\uff084\uff09\u200b\u4e09\u8005\u200b\u5173\u7cfb\u200b\uff1a\u200b\u5f53\u200b \\(X\uff08z\uff09\\) \u200b\u6536\u655b\u200b\u57df\u200b\u5305\u542b\u200b\u5355\u4f4d\u200b\u5706\u65f6\u200b\uff0c\\(X(k) = X(z)\\bigg|_{z=e^{j\\frac{2\\pi}{N}k}} = X(e^{j\\omega})\\bigg|_{\\omega=\\frac{2\\pi}{N}k}\\) </li> </ul> \u200b\u7b80\u8ff0\u200bDFT\uff08FFT\uff09\u200b\u5bf9\u200b\u6a21\u62df\u4fe1\u53f7\u200b\u8fdb\u884c\u200b\u8c31\u5206\u6790\u200b\u7684\u200b\u8bef\u5dee\u200b\u6765\u6e90\u200b\uff0c\u200b\u5e76\u200b\u8bf4\u660e\u200b\u5982\u4f55\u200b\u51cf\u5c0f\u200b\u8bef\u5dee\u200b <ul> <li>\uff081\uff09\u200b\u9891\u8c31\u200b\u6df7\u53e0\u200b\uff1a  </li> <li>\uff082\uff09\u200b\u622a\u65ad\u200b\u6548\u5e94\u200b\uff1a  </li> <li>\uff083\uff09\u200b\u6805\u680f\u200b\u6548\u5e94\u200b\uff1a  </li> </ul> \u200b\u6574\u6570\u200b\u56e0\u5b50\u200bD\u200b\u62bd\u53d6\u200b\u7684\u200b\u539f\u7406\u200b\u65b9\u6846\u56fe\u200b\u4ee5\u53ca\u200b\u5404\u200b\u6a21\u5757\u200b\u4f5c\u7528\u200b <p></p>"},{"location":"NBU-NOTEBOOK/DSP/cp01/","title":"\u8fde\u7eed\u200b\u65f6\u95f4\u200b\u4fe1\u53f7\u200b\u7684\u200b\u91c7\u6837","text":""},{"location":"NBU-NOTEBOOK/DSP/cp01/#_1","title":"\u8fde\u7eed\u200b\u65f6\u95f4\u200b\u4fe1\u53f7\u200b\u7684\u200b\u91c7\u6837","text":""},{"location":"NBU-NOTEBOOK/DSP/cp02/","title":"\u7ebf\u6027\u200b\u662f\u200b\u4e0d\u53d8\u200b\u7cfb\u7edf\u200b\u7684\u200b\u53d8\u6362\u5206\u6790","text":""},{"location":"NBU-NOTEBOOK/DSP/cp02/#_1","title":"\u7ebf\u6027\u200b\u662f\u200b\u4e0d\u53d8\u200b\u7cfb\u7edf\u200b\u7684\u200b\u53d8\u6362\u5206\u6790","text":""},{"location":"NBU-NOTEBOOK/DSP/cp03/","title":"\u79bb\u6563\u200b\u65f6\u95f4\u200b\u7cfb\u7edf\u7ed3\u6784","text":""},{"location":"NBU-NOTEBOOK/DSP/cp03/#_1","title":"\u79bb\u6563\u200b\u65f6\u95f4\u200b\u7cfb\u7edf\u7ed3\u6784","text":""},{"location":"NBU-NOTEBOOK/DSP/cp04/","title":"\u79bb\u6563\u200b\u65f6\u95f4\u200b\u6ee4\u6ce2\u5668","text":""},{"location":"NBU-NOTEBOOK/DSP/cp04/#_1","title":"\u79bb\u6563\u200b\u65f6\u95f4\u200b\u6ee4\u6ce2\u5668","text":""},{"location":"NBU-NOTEBOOK/DSP/cp05/","title":"\u79bb\u6563\u200b\u5085\u91cc\u53f6\u200b\u53d8\u6362\u200bDFT\u3001DFS","text":""},{"location":"NBU-NOTEBOOK/DSP/cp05/#dftdfs","title":"\u79bb\u6563\u200b\u5085\u91cc\u53f6\u200b\u